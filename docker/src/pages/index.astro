---
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('dashboard-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
            return;
          }
          const prefersDark =
            typeof window.matchMedia === 'function' &&
            window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        } catch {}
      })();
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.14.0/dist/cdn.min.js"></script>
    <style>
      :root {
        --bg: #ffd319;
        --paper: #fffdf5;
        --ink: #111111;
        --muted: #585858;
        --danger: #9a1d1d;
        --accent: #1a6f4b;
        --line: #111111;
        --button-bg: #1a6f4b;
        --button-bg-active: #14563a;
        --button-text: #ffffff;
        --side-card-height: 154px;
        --overall-side-height: calc((var(--side-card-height) * 4) + (0.45rem * 3) + 1rem);
      }
      html[data-theme="dark"] {
        --bg: #151515;
        --paper: #212121;
        --ink: #ffffff;
        --muted: #bfbfbf;
        --danger: #ff6b6b;
        --accent: #4fc98c;
        --line: #ffd319;
        --button-bg: #1a1a1a;
        --button-bg-active: #2a2a2a;
        --button-text: #ffffff;
        color-scheme: dark;
      }

      * { box-sizing: border-box; }
      [x-cloak] { display: none !important; }

      body {
        margin: 0;
        font-size: 14px;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 18%, #fff1a6 0 12%, transparent 13%),
          radial-gradient(circle at 80% 8%, #ffe06d 0 10%, transparent 11%),
          var(--bg);
        font-family: "Space Grotesk", "IBM Plex Sans", "Segoe UI", sans-serif;
      }
      html[data-theme="dark"] body {
        background:
          radial-gradient(circle at 12% 18%, #2f2f2f 0 12%, transparent 13%),
          radial-gradient(circle at 80% 8%, #262626 0 10%, transparent 11%),
          var(--bg);
      }

      .wrap {
        max-width: 1120px;
        margin: 0 auto;
        padding: 1.2rem;
        zoom: 0.75;
      }
      .app-shell {
        transition: filter .2s ease, opacity .2s ease;
      }
      .app-shell.app-shell-locked {
        filter: grayscale(1);
        opacity: 0.45;
        pointer-events: none;
        user-select: none;
      }

      .hero {
        background: var(--paper);
        border: 3px solid var(--line);
        box-shadow: 8px 8px 0 var(--line);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        display: grid;
        gap: .8rem;
      }
      .hero-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .6rem;
      }
      .hero-tools {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .badge {
        width: fit-content;
        border: 2px solid var(--line);
        background: var(--bg);
        padding: .22rem .5rem;
        border-radius: 999px;
        font-size: .74rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
      }
      .theme-toggle {
        width: 2rem;
        height: 2rem;
        padding: .2rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(1.7rem, 4vw, 3rem);
        line-height: 1.1;
      }
      .joke-line {
        margin: 0;
        font-style: italic;
        font-weight: 350;
      }
      .meta-line {
        margin: 0;
        font-weight: 600;
        display: flex;
        gap: .45rem;
        flex-wrap: wrap;
        align-items: center;
      }
      .meta-line .sep {
        color: #777;
      }
      .hero-actions {
        display: flex;
        align-items: center;
        gap: .5rem;
      }

      .muted { color: var(--muted); }
      .small { font-size: .88rem; }
      a { color: #004fa1; }

      .layout {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: max-content minmax(0, 1fr) max-content;
        gap: 1rem;
        align-items: start;
      }
      .news-pane {
        width: 100%;
        min-height: var(--overall-side-height);
        max-height: var(--overall-side-height);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 2px solid var(--line);
        border-radius: 12px;
        padding: .6rem;
        box-shadow: none;
        background: #ffffff;
      }
      html[data-theme="dark"] .news-pane {
        background: transparent;
      }
      .news-scroll {
        overflow-y: auto;
        padding-right: .25rem;
      }
      .news-list {
        display: grid;
        gap: .55rem;
      }
      .news-item {
        border: 2px solid var(--line);
        border-radius: 10px;
        background: #fff;
        padding: .5rem;
        display: grid;
        gap: .35rem;
        min-height: var(--side-card-height);
        max-height: var(--side-card-height);
        width: 100%;
        overflow: hidden;
      }
      html[data-theme="dark"] .news-item {
        background: #171717;
      }
      .news-thumb {
        width: 100%;
        height: 56px;
        border-radius: 8px;
        border: 1px solid var(--line);
        display: block;
        object-fit: cover;
      }
      .news-link {
        color: #00438f;
        text-decoration: none;
        font-weight: 700;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      html[data-theme="dark"] .news-link {
        color: #8fc6ff;
      }
      .news-meta {
        font-size: .75rem;
        color: var(--muted);
      }

      .panel {
        background: var(--paper);
        border: 3px solid var(--line);
        border-radius: 12px;
        box-shadow: 6px 6px 0 var(--line);
        padding: .9rem;
      }

      .panel h2 {
        margin: 0 0 .6rem;
        font-size: 1.08rem;
      }

      .stack { display: grid; gap: .6rem; }

      input, select, textarea, button {
        font: inherit;
        border-radius: 10px;
      }

      input, select, textarea {
        width: 100%;
        border: 2px solid var(--line);
        background: #ffffff;
        padding: .55rem .65rem;
      }
      html[data-theme="dark"] input,
      html[data-theme="dark"] select,
      html[data-theme="dark"] textarea {
        background: #121212;
        color: var(--ink);
      }

      textarea { min-height: 74px; resize: vertical; }

      button {
        border: 2px solid var(--line);
        background: var(--button-bg);
        color: var(--button-text);
        padding: .5rem .7rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 3px 3px 0 var(--line);
      }

      button:hover { transform: translate(-1px, -1px); }
      button.alt,
      button.warn,
      button.ghost {
        background: var(--button-bg);
        color: var(--button-text);
      }

      .row {
        display: flex;
        gap: .55rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .categories-pane {
        min-height: var(--overall-side-height);
        max-height: var(--overall-side-height);
        overflow: hidden;
        align-self: start;
        padding: .6rem;
        border: 3px solid var(--line);
        border-radius: 12px;
        box-shadow: 6px 6px 0 var(--line);
        background: #ffffff;
      }
      html[data-theme="dark"] .categories-pane {
        background: transparent;
        box-shadow: none;
      }

      .categories {
        display: grid;
        gap: .9rem;
        justify-items: start;
        align-content: start;
        width: 100%;
        height: 100%;
        overflow-y: auto;
        padding-right: .25rem;
      }

      .category {
        width: 100%;
        max-width: 100%;
        padding: 0 0 .75rem;
        border-bottom: 2px solid var(--line);
      }
      .category:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .cat-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .6rem;
      }
      .drag-group {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
      }
      .drag-handle {
        border: 2px solid var(--line);
        background: #fff6c3;
        border-radius: 8px;
        width: 1.8rem;
        height: 1.8rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: grab;
        user-select: none;
        font-weight: 700;
      }
      html[data-theme="dark"] .drag-handle {
        background: #2c2c2c;
        color: var(--ink);
      }
      .drag-handle:active {
        cursor: grabbing;
      }

      .cat-title {
        display: flex;
        align-items: center;
        gap: .55rem;
        font-size: 1.05rem;
        font-weight: 700;
      }

      .count-chip {
        min-width: 1.8rem;
        height: 1.8rem;
        padding: 0 .45rem;
        border: 2px solid var(--line);
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        font-weight: 700;
        background: var(--bg);
      }

      .links {
        display: grid;
        gap: .55rem;
        margin-top: .65rem;
        width: 100%;
      }

      .link-item {
        border: 2px solid var(--line);
        border-radius: 10px;
        background: #fff;
        padding: .65rem;
        width: 100%;
        max-width: 100%;
      }
      html[data-theme="dark"] .link-item {
        background: #171717;
      }

      .link-top {
        display: flex;
        align-items: center;
        gap: .55rem;
      }
      .link-main {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        min-width: 0;
      }
      .link-actions {
        margin-left: auto;
        display: inline-flex;
        gap: .45rem;
        flex: 0 0 auto;
      }
      .favicon {
        width: 16px;
        height: 16px;
        border-radius: 3px;
        flex: 0 0 16px;
        object-fit: contain;
        background: transparent;
      }

      .link-name {
        font-weight: 700;
        text-decoration: none;
        color: #00438f;
      }
      html[data-theme="dark"] .link-name,
      html[data-theme="dark"] a {
        color: #8fc6ff;
      }

      .empty {
        border: 2px dashed var(--line);
        border-radius: 10px;
        background: #fff9d9;
        padding: .7rem;
      }
      html[data-theme="dark"] .empty {
        background: #1f1f1f;
      }
      .panel-tabs {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
      }
      .clocks-box {
        border: 3px solid var(--line);
        border-radius: 12px;
        background: #fff9d9;
        padding: .5rem .65rem;
        min-height: var(--overall-side-height);
        max-height: var(--overall-side-height);
        overflow: hidden;
        box-shadow: 6px 6px 0 var(--line);
      }
      html[data-theme="dark"] .clocks-box {
        background: #1f1f1f;
        box-shadow: none;
      }
      .clocks-side {
        display: flex;
        justify-content: flex-end;
        align-items: flex-start;
        width: 170px;
      }
      .clocks-row {
        display: flex;
        gap: .45rem;
        flex-direction: column;
        align-items: stretch;
      }
      .clock-tile {
        border: 2px solid var(--line);
        border-radius: 10px;
        background: var(--paper);
        min-width: 150px;
        height: var(--side-card-height);
        padding: .35rem .45rem;
        display: grid;
        justify-items: center;
        gap: .15rem;
      }
      html[data-theme="dark"] .clock-tile {
        background: #171717;
      }
      .clock-city {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        font-weight: 700;
        color: var(--muted);
      }
      .clock-face {
        width: 68px;
        height: 68px;
        display: block;
      }
      .clock-dial {
        fill: #fff;
        stroke: var(--line);
        stroke-width: 3;
      }
      html[data-theme="dark"] .clock-dial {
        fill: #151515;
      }
      .clock-mark {
        stroke: var(--line);
        stroke-width: 2;
        stroke-linecap: round;
      }
      .clock-hour {
        stroke: var(--ink);
        stroke-width: 3.2;
        stroke-linecap: round;
      }
      .clock-minute {
        stroke: var(--ink);
        stroke-width: 2.2;
        stroke-linecap: round;
      }
      .clock-second {
        stroke: #d33;
        stroke-width: 1.2;
        stroke-linecap: round;
      }
      .clock-center {
        fill: var(--line);
      }
      .clock-meta {
        font-size: .72rem;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
        text-align: center;
      }
      .clock-digital {
        font-size: .82rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        line-height: 1;
      }
      .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        z-index: 40;
      }
      .modal-card {
        width: min(480px, 100%);
      }
      .ops-note {
        margin: 0;
        line-height: 1.4;
      }
      .ops-status {
        margin: 0;
        font-weight: 700;
      }
      .ops-status.success {
        color: var(--accent);
      }
      .ops-status.error {
        color: var(--danger);
      }
      .ops-actions {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
      }
      .modal-error {
        color: #000000;
      }
      html[data-theme="dark"] .modal-error {
        color: #ffffff;
      }
      .panel-tabs-left {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        align-items: center;
      }
      .panel-tabs-right {
        margin-left: auto;
        min-width: 220px;
        max-width: 320px;
      }
      .tab-item {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
      }
      .tab-btn.active {
        background: var(--button-bg-active);
        color: var(--button-text);
      }
      html[data-theme="dark"] .panel,
      html[data-theme="dark"] .hero {
        background: #1f1f1f;
      }
      html[data-theme="dark"] .badge,
      html[data-theme="dark"] .count-chip {
        background: #303030;
        color: var(--ink);
      }
      html[data-theme="dark"] .tab-btn {
        color: var(--button-text);
      }
      html[data-theme="dark"] .hero,
      html[data-theme="dark"] .panel,
      html[data-theme="dark"] .link-item,
      html[data-theme="dark"] button,
      html[data-theme="dark"] .tab-btn,
      html[data-theme="dark"] .drag-handle {
        box-shadow: none;
      }
      .restart-lock {
        position: fixed;
        inset: 0;
        z-index: 90;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(128, 128, 128, 0.58);
      }
      .restart-lock-card {
        width: min(460px, 100%);
        text-align: center;
      }
      .restart-lock-card p {
        margin: 0;
        line-height: 1.5;
      }

      @media (max-width: 900px) {
        .layout {
          grid-template-columns: 1fr;
        }
        .clocks-side {
          justify-content: flex-start;
        }
        .clocks-row {
          flex-direction: row;
          overflow-x: auto;
        }
      }
    </style>
  </head>
  <body>
    <div x-data="dashboardApp()">
    <main class="wrap app-shell" :class="{ 'app-shell-locked': appLocked }">
      <section class="hero">
        <div class="hero-top">
          <span class="badge">BootCamp / Week1 / Personal Dashboard</span>
          <div class="hero-tools">
            <button
              class="small"
              type="button"
              x-show="dbOps.enabled"
              x-cloak
              @click="openDbOpsModal()"
            >DB Backup/Restore</button>
            <button
              type="button"
              class="theme-toggle"
              @click="toggleTheme()"
              :title="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
              :aria-label="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
            >
              <svg
                x-show="theme === 'light'"
                viewBox="0 0 24 24"
                width="14"
                height="14"
                fill="currentColor"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 18h6"></path>
                <path d="M10 21h4"></path>
                <path d="M12 2a7 7 0 0 0-4 12.8V17h8v-2.2A7 7 0 0 0 12 2z"></path>
              </svg>
              <svg
                x-show="theme === 'dark'"
                viewBox="0 0 24 24"
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 18h6"></path>
                <path d="M10 21h4"></path>
                <path d="M12 2a7 7 0 0 0-4 12.8V17h8v-2.2A7 7 0 0 0 12 2z"></path>
              </svg>
            </button>
          </div>
        </div>
        <p class="meta-line small">
          <span x-text="profile.name"></span>
          <span class="sep">|</span>
          <span x-text="profile.title"></span>
          <span class="sep">|</span>
          <a :href="`mailto:${profile.email}`" x-text="profile.email"></a>
          <span class="sep">|</span>
          <span x-text="timeDisplay"></span>
          <span class="sep">|</span>
          <span x-text="todayDisplay"></span>
          <span class="sep">|</span>
          <span x-text="`Categories: ${totalCategories()} | Links: ${totalLinks()}`"></span>
        </p>
        <p class="joke-line muted" x-text="jokeText"></p>
        <div class="hero-actions">
          <button class="alt small" type="button" @click="openCategoryModal()">+ Category</button>
          <button class="alt small" type="button" @click="openLinkModal()">+ Link</button>
        </div>
        <div class="panel-tabs">
          <div class="panel-tabs-left">
            <template x-for="panel in panels" :key="panel.id">
              <div class="tab-item" @dragover.prevent @drop.prevent.stop="onPanelDrop(panel.id, $event)">
                <span
                  class="drag-handle"
                  title="Drag panel"
                  draggable="true"
                  @dragstart="onPanelDragStart(panel.id, $event)"
                  @dragend="onDragEnd()"
                >::</span>
                <button
                  type="button"
                  class="tab-btn"
                  :class="{ active: panel.id === activePanelId }"
                  @click="switchPanel(panel.id)"
                  @dragover.prevent
                  @drop.prevent.stop="onPanelTabDrop(panel.id, $event)"
                  x-text="panel.name"
                ></button>
              </div>
            </template>
          </div>
          <div class="panel-tabs-right">
            <input x-model="linkSearch" placeholder="Search link names..." />
          </div>
        </div>
      </section>

      <section class="layout">
        <section class="categories-pane">
          <section class="categories">
            <template x-for="category in displayCategories()" :key="category.id">
              <article class="category">
                <div class="cat-head" @dragover.prevent @drop.prevent.stop="onCategoryDrop(category.id)">
                  <div class="drag-group">
                    <span
                      class="drag-handle"
                      title="Drag category"
                      draggable="true"
                      @dragstart="onCategoryDragStart(category.id, $event)"
                      @dragend="onDragEnd()"
                    >::</span>
                    <h3 class="cat-title">
                      <span x-text="category.name"></span>
                      <span class="count-chip" x-text="category.links.length"></span>
                    </h3>
                  </div>
                  <button class="category-delete trash-icon-btn small" @click="deleteCategory(category.id)" aria-label="Delete category" title="Delete category">🗑</button>
                </div>

                <template x-if="!categoryHasVisibleLinks(category)">
                  <p class="empty small muted" x-text="linkSearch ? 'No matching links.' : 'No links yet.'"></p>
                </template>

                <div
                  class="links"
                  x-show="categoryHasVisibleLinks(category)"
                  @dragover.prevent
                  @drop.prevent.stop="onLinkDropToCategoryEnd(category.id)"
                >
                  <template x-for="link in category.links" :key="link.id">
                    <div
                      class="link-item"
                      x-show="matchesLinkSearch(link.name)"
                      @dragover.prevent
                      @drop.prevent.stop="onLinkDrop(category.id, link.id, $event)"
                    >
                      <div class="link-top">
                        <div class="link-main">
                          <span
                            class="drag-handle"
                            title="Drag link"
                            draggable="true"
                            @dragstart="onLinkDragStart(link.id, category.id, $event)"
                            @dragend="onDragEnd()"
                          >::</span>
                          <img
                            class="favicon"
                            :src="getFaviconUrl(link.url)"
                            @error="onFaviconError($event)"
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                          <a class="link-name" :href="link.url" target="_blank" rel="noreferrer" x-text="link.name"></a>
                        </div>
                        <div class="link-actions">
                          <button class="link-action small" @click="startEdit(link)" aria-label="Edit link" title="Edit link">✎</button>
                          <button class="link-action trash-icon-btn small" @click="deleteLink(link.id)" aria-label="Delete link" title="Delete link">🗑</button>
                        </div>
                      </div>
                      <p class="small muted" x-text="link.description"></p>
                    </div>
                  </template>
                </div>
              </article>
            </template>
          </section>
        </section>
        <aside class="panel news-pane">
          <h2>Google News Global</h2>
          <div class="news-scroll">
            <p class="small muted" x-show="newsError" x-text="newsError"></p>
            <div class="news-list" x-show="newsItems.length">
              <template x-for="item in newsItems" :key="item.link">
                <article class="news-item">
                  <img
                    class="news-thumb"
                    x-show="item.image"
                    :src="item.image"
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                  <a class="news-link" :href="item.link" target="_blank" rel="noreferrer" x-text="item.title"></a>
                  <p class="news-meta" x-text="item.source ? `${item.source} | ${item.pubDate}` : item.pubDate"></p>
                </article>
              </template>
            </div>
            <p class="small muted" x-show="!newsItems.length && !newsError">No news available right now.</p>
          </div>
        </aside>
        <aside class="clocks-side">
          <div class="clocks-box">
            <div class="clocks-row">
              <template x-for="clock in worldClocks" :key="clock.city">
                <div class="clock-tile">
                  <span class="clock-city" x-text="clock.city"></span>
                  <svg class="clock-face" viewBox="0 0 100 100" aria-hidden="true">
                    <circle class="clock-dial" cx="50" cy="50" r="46"></circle>
                    <line class="clock-mark" x1="50" y1="10" x2="50" y2="16"></line>
                    <line class="clock-mark" x1="90" y1="50" x2="84" y2="50"></line>
                    <line class="clock-mark" x1="50" y1="90" x2="50" y2="84"></line>
                    <line class="clock-mark" x1="10" y1="50" x2="16" y2="50"></line>
                    <line
                      class="clock-hour"
                      x1="50"
                      y1="50"
                      x2="50"
                      y2="30"
                      :transform="`rotate(${clock.hourDeg} 50 50)`"
                    ></line>
                    <line
                      class="clock-minute"
                      x1="50"
                      y1="50"
                      x2="50"
                      y2="22"
                      :transform="`rotate(${clock.minuteDeg} 50 50)`"
                    ></line>
                    <line
                      class="clock-second"
                      x1="50"
                      y1="54"
                      x2="50"
                      y2="18"
                      :transform="`rotate(${clock.secondDeg} 50 50)`"
                    ></line>
                    <circle class="clock-center" cx="50" cy="50" r="2.8"></circle>
                  </svg>
                  <span class="clock-digital" x-text="clock.time"></span>
                  <span class="clock-meta" x-text="clock.meta"></span>
                </div>
              </template>
            </div>
          </div>
        </aside>
      </section>

      <div
        class="modal-backdrop"
        x-cloak
        x-show="showCategoryModal"
        @click.self="closeCategoryModal()"
      >
        <article class="panel modal-card">
          <h2>Create Category</h2>
          <p class="small modal-error" x-show="categoryErrorMessage" x-text="categoryErrorMessage"></p>
          <form class="stack" @submit.prevent="addCategory()">
            <input
              x-model="newCategory"
              placeholder="Category name"
              required
              @keydown.escape.window="closeCategoryModal()"
            />
            <div class="row">
              <button class="alt" type="submit">Create</button>
              <button class="ghost" type="button" @click="closeCategoryModal()">Cancel</button>
            </div>
          </form>
        </article>
      </div>

      <div
        class="modal-backdrop"
        x-cloak
        x-show="showLinkModal"
        @click.self="closeLinkModal()"
      >
        <article class="panel modal-card">
          <h2>Add / Edit Link</h2>
          <p class="small modal-error" x-show="linkErrorMessage" x-text="linkErrorMessage"></p>
          <form @submit.prevent="submitLink()" class="stack">
            <input x-model="form.name" placeholder="Link name" required />
            <input x-model="form.url" type="url" placeholder="https://example.com" required />
            <select x-model.number="form.categoryId" required>
              <option value="">Select category</option>
              <template x-for="category in filteredCategories()" :key="category.id">
                <option :value="category.id" x-text="category.name"></option>
              </template>
            </select>
            <textarea x-model="form.description" placeholder="Description (optional)"></textarea>
            <div class="row">
              <button class="alt" type="submit" x-text="editingId ? 'Save Changes' : 'Add Link'"></button>
              <button class="ghost" type="button" @click="closeLinkModal()">Cancel</button>
            </div>
          </form>
        </article>
      </div>

      <div
        class="modal-backdrop"
        x-cloak
        x-show="showDbOpsModal"
        @click.self="closeDbOpsModal()"
      >
        <article class="panel modal-card">
          <h2>DB Backup/Restore</h2>
          <p class="small muted ops-note">
            Create an immediate PostgreSQL backup or restore one of the latest
            <span x-text="dbOps.restoreLimit"></span>
            saved backups. Only
            <span x-text="dbOps.restoreLimit"></span>
            backups are kept. If a new backup would exceed that limit, older backup files are deleted. Backups older than
            <span x-text="dbOps.retentionDays"></span>
            days are pruned after each successful backup.
          </p>
          <p class="small muted ops-note">
            After restoring a backup, restart the personal-dashboard so the restored database is picked up.
          </p>
          <form class="stack" @submit.prevent="createDatabaseBackup()">
            <input
              x-model="dbOpsSecret"
              type="password"
              placeholder="Admin secret"
              autocomplete="current-password"
              required
            />
            <select x-model="selectedBackupFilename" :disabled="dbOpsBusy || !dbOps.backups.length">
              <option value="">Select backup to restore</option>
              <template x-for="backup in dbOps.backups" :key="backup.filename">
                <option :value="backup.filename" x-text="backup.restoreName"></option>
              </template>
            </select>
            <p class="small muted ops-note" x-show="!dbOps.backups.length">
              No backups are currently available to restore.
            </p>
            <p class="small ops-status error" x-show="dbOpsError" x-text="dbOpsError"></p>
            <p class="small ops-status success" x-show="dbOpsMessage" x-text="dbOpsMessage"></p>
            <div class="ops-actions">
              <button class="alt" type="submit" :disabled="dbOpsBusy">
                <span x-text="dbOpsBusy && dbOpsAction === 'backup' ? 'Creating...' : 'Create Backup'"></span>
              </button>
              <button
                class="warn"
                type="button"
                :disabled="dbOpsBusy || !selectedBackupFilename"
                @click="restoreSelectedBackup()"
              >
                <span x-text="dbOpsBusy && dbOpsAction === 'restore' ? 'Restoring...' : 'Restore Backup'"></span>
              </button>
              <button class="ghost" type="button" @click="closeDbOpsModal()">Close</button>
            </div>
          </form>
        </article>
      </div>

    </main>
    <div class="restart-lock" x-cloak x-show="appLocked">
      <article class="panel restart-lock-card">
        <h2>Restart Required</h2>
        <p class="small" x-text="restoreLockMessage"></p>
      </article>
    </div>
    </div>

    <script is:inline>
      window.dashboardApp = function () {
        const log = (event, meta = {}) => {
          console.info(`[dashboard] ${event}`, meta);
        };
        const restoreLockStorageKey = 'dashboard-restore-lock';

        return {
          inactivityMs: 30 * 1000,
          newsRefreshMs: 5 * 60 * 1000,
          inactivityTimer: null,
          newsTimer: null,
          appInstanceId: '',
          appLocked: false,
          restoreLockMessage: 'Restart the personal-dashboard to resume using the restored database.',
          theme: 'light',
          profile: { name: 'Loading...', title: '', email: '' },
          dbOps: {
            enabled: false,
            retentionDays: 7,
            restoreLimit: 5,
            backups: []
          },
          panels: [],
          activePanelId: null,
          categories: [],
          linkSearch: '',
          newsItems: [],
          newsError: '',
          dragPanelId: null,
          dragCategoryId: null,
          dragLinkId: null,
          dragFromCategoryId: null,
          errorMessage: '',
          categoryErrorMessage: '',
          linkErrorMessage: '',
          showCategoryModal: false,
          showLinkModal: false,
          showDbOpsModal: false,
          newCategory: '',
          timeDisplay: '',
          todayDisplay: '',
          worldClocks: [],
          clocksIntervalId: null,
          jokeText: 'Loading a joke...',
          jokeLoaded: false,
          dbOpsSecret: '',
          selectedBackupFilename: '',
          dbOpsBusy: false,
          dbOpsAction: '',
          dbOpsError: '',
          dbOpsMessage: '',
          editingId: null,
          form: {
            name: '',
            url: '',
            description: '',
            categoryId: ''
          },

          async init() {
            this.theme = document.documentElement.getAttribute('data-theme') || 'light';
            this.setupInactivityWatcher();
            this.setupPanelHotkeys();
            this.timeDisplay = new Date().toLocaleTimeString(undefined, {
              hour: 'numeric',
              minute: '2-digit',
              timeZoneName: 'short'
            });
            this.todayDisplay = new Date().toLocaleDateString(undefined, {
              weekday: 'long',
              month: 'long',
              day: 'numeric',
              year: 'numeric'
            });
            this.updateClocks();
            this.clocksIntervalId = window.setInterval(() => this.updateClocks(), 1000);
            await Promise.all([this.loadJoke(), this.load(), this.loadNews()]);
            this.setupNewsAutoRefresh();
          },

          syncRestoreLock() {
            try {
              const lockedInstanceId = localStorage.getItem(restoreLockStorageKey) || '';
              if (lockedInstanceId && lockedInstanceId === this.appInstanceId) {
                this.appLocked = true;
                this.restoreLockMessage = 'Database restore completed. Restart the personal-dashboard to ensure the restored database is picked up.';
                return;
              }
              if (lockedInstanceId && lockedInstanceId !== this.appInstanceId) {
                localStorage.removeItem(restoreLockStorageKey);
              }
            } catch {}

            this.appLocked = false;
            this.restoreLockMessage = 'Restart the personal-dashboard to resume using the restored database.';
          },

          lockDashboardUntilRestart() {
            if (!this.appInstanceId) return;

            try {
              localStorage.setItem(restoreLockStorageKey, this.appInstanceId);
            } catch {}

            this.appLocked = true;
            this.restoreLockMessage = 'Database restore completed. Restart the personal-dashboard to ensure the restored database is picked up.';
            this.showDbOpsModal = false;
          },

          toggleTheme() {
            if (this.appLocked) return;
            this.theme = this.theme === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', this.theme);
            try {
              localStorage.setItem('dashboard-theme', this.theme);
            } catch {}
          },

          openCategoryModal() {
            this.categoryErrorMessage = '';
            this.showCategoryModal = true;
          },

          closeCategoryModal() {
            this.showCategoryModal = false;
            this.newCategory = '';
            this.categoryErrorMessage = '';
          },

          openLinkModal() {
            this.linkErrorMessage = '';
            this.showLinkModal = true;
          },

          closeLinkModal() {
            this.showLinkModal = false;
            this.linkErrorMessage = '';
            this.resetForm();
          },

          openDbOpsModal() {
            this.dbOpsError = '';
            this.dbOpsMessage = '';
            if (!this.selectedBackupFilename && this.dbOps.backups.length) {
              this.selectedBackupFilename = this.dbOps.backups[0].filename;
            }
            this.showDbOpsModal = true;
          },

          closeDbOpsModal() {
            this.showDbOpsModal = false;
            this.dbOpsSecret = '';
            this.dbOpsBusy = false;
            this.dbOpsAction = '';
            this.dbOpsError = '';
            this.dbOpsMessage = '';
          },

          setupInactivityWatcher() {
            const resetTimer = () => {
              if (this.inactivityTimer) clearTimeout(this.inactivityTimer);
              this.inactivityTimer = setTimeout(() => {
                window.location.reload();
              }, this.inactivityMs);
            };

            ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'pointerdown']
              .forEach((eventName) => {
                window.addEventListener(eventName, resetTimer, { passive: true });
              });

            resetTimer();
          },

          setupNewsAutoRefresh() {
            if (this.newsTimer) clearInterval(this.newsTimer);
            this.newsTimer = setInterval(() => {
              this.loadNews();
            }, this.newsRefreshMs);
          },

          setupPanelHotkeys() {
            window.addEventListener('keydown', (event) => {
              const active = document.activeElement;
              const tag = (active?.tagName || '').toLowerCase();
              const isTypingContext =
                tag === 'input' ||
                tag === 'textarea' ||
                tag === 'select' ||
                active?.isContentEditable;

              if (isTypingContext) return;
              if (event.metaKey || event.ctrlKey || event.altKey) return;

              const keyNum = Number(event.key);
              if (!Number.isInteger(keyNum) || keyNum < 1 || keyNum > 9) return;

              const targetPanel = this.panels[keyNum - 1];
              if (!targetPanel) return;

              event.preventDefault();
              this.switchPanel(targetPanel.id);
            });
          },

          updateClocks() {
            const now = new Date();
            const timeParts = (timeZone) => {
              const parts = new Intl.DateTimeFormat('en-US', {
                hour: 'numeric',
                minute: 'numeric',
                second: 'numeric',
                hour12: false,
                timeZone
              }).formatToParts(now);
              const read = (type) => Number(parts.find((part) => part.type === type)?.value || 0);
              return { hour: read('hour'), minute: read('minute'), second: read('second') };
            };
            const formatDigital = ({ hour, minute, second }) =>
              `${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')}:${String(second).padStart(2, '0')}`;
            const formatMeta = (timeZone) => now.toLocaleString(undefined, {
              weekday: 'short',
              month: 'short',
              day: 'numeric',
              timeZoneName: 'short',
              timeZone
            });
            this.worldClocks = [
              { city: 'New York', zone: 'America/New_York' },
              { city: 'Berlin', zone: 'Europe/Berlin' },
              { city: 'Chennai', zone: 'Asia/Kolkata' },
              { city: 'Japan', zone: 'Asia/Tokyo' }
            ].map((item) => {
              const t = timeParts(item.zone);
              return {
                hourDeg: ((t.hour % 12) * 30) + (t.minute * 0.5),
                minuteDeg: (t.minute * 6) + (t.second * 0.1),
                secondDeg: t.second * 6,
                city: item.city,
                time: formatDigital(t),
                meta: formatMeta(item.zone)
              };
            });
          },

          async loadJoke() {
            if (this.jokeLoaded) return;
            try {
              const response = await fetch('https://api.chucknorris.io/jokes/random');
              if (!response.ok) {
                throw new Error(`Joke request failed with ${response.status}`);
              }
              const data = await response.json();
              this.jokeText = data?.value || 'No joke available right now.';
              this.jokeLoaded = true;
            } catch {
              this.jokeText = 'No joke available right now.';
              this.jokeLoaded = true;
            }
          },

          async load() {
            log('load:start');
            const response = await fetch('/api/dashboard.json');
            if (!response.ok) {
              this.errorMessage = 'Failed to load dashboard data';
              return;
            }
            const data = await response.json();
            this.profile = data.profile;
            this.appInstanceId = String(data.appInstanceId || '');
            const nextDbOps = data.dbOps || {};
            this.dbOps = {
              enabled: Boolean(nextDbOps.enabled),
              retentionDays: Number.isInteger(nextDbOps.retentionDays) ? nextDbOps.retentionDays : 7,
              restoreLimit: Number.isInteger(nextDbOps.restoreLimit) ? nextDbOps.restoreLimit : 5,
              backups: Array.isArray(nextDbOps.backups) ? nextDbOps.backups : []
            };
            if (this.selectedBackupFilename) {
              const selectedStillExists = this.dbOps.backups.some(
                (backup) => backup.filename === this.selectedBackupFilename
              );
              if (!selectedStillExists) {
                this.selectedBackupFilename = this.dbOps.backups[0]?.filename || '';
              }
            } else {
              this.selectedBackupFilename = this.dbOps.backups[0]?.filename || '';
            }
            this.panels = data.panels || [];
            this.categories = data.categories;
            if (
              this.activePanelId &&
              !this.panels.some((panel) => panel.id === this.activePanelId)
            ) {
              this.activePanelId = null;
            }
            if (!this.activePanelId && this.panels.length > 0) {
              this.activePanelId = this.panels[0].id;
            }
            if (
              this.form.categoryId &&
              !this.filteredCategories().some((category) => category.id === this.form.categoryId)
            ) {
              this.form.categoryId = '';
            }
            this.errorMessage = '';
            this.syncRestoreLock();
            log('load:done', { categories: this.categories.length });
          },

          async performDbOperation(path, action, body = null) {
            const secret = this.dbOpsSecret.trim();
            if (!secret) {
              this.dbOpsError = 'Admin secret is required';
              this.dbOpsMessage = '';
              return null;
            }

            this.dbOpsBusy = true;
            this.dbOpsAction = action;
            this.dbOpsError = '';
            this.dbOpsMessage = '';

            try {
              const headers = {
                'x-db-ops-secret': secret
              };
              const requestInit = {
                method: 'POST',
                headers
              };
              if (body) {
                headers['Content-Type'] = 'application/json';
                requestInit.body = JSON.stringify(body);
              }

              const response = await fetch(path, {
                ...requestInit
              });
              const payload = await response.json().catch(() => ({}));

              if (!response.ok) {
                throw new Error(payload.error || `Failed to ${action} database`);
              }

              this.dbOpsMessage = payload.message || `Database ${action} completed`;
              return payload;
            } catch (error) {
              this.dbOpsError = error.message || `Failed to ${action} database`;
              return null;
            } finally {
              this.dbOpsBusy = false;
              this.dbOpsAction = '';
            }
          },

          async createDatabaseBackup() {
            const payload = await this.performDbOperation('/api/admin/db/backup', 'backup');
            if (!payload) return;
            await this.load();
            this.dbOpsMessage = payload.message || this.dbOpsMessage;
          },

          async restoreSelectedBackup() {
            if (!this.selectedBackupFilename) {
              this.dbOpsError = 'Select a backup to restore';
              this.dbOpsMessage = '';
              return;
            }

            const selectedBackup = this.dbOps.backups.find(
              (backup) => backup.filename === this.selectedBackupFilename
            );
            const restoreName = selectedBackup?.restoreName || this.selectedBackupFilename;

            if (!window.confirm(`Restore backup ${restoreName}? This will overwrite the current database contents.`)) {
              return;
            }

            const payload = await this.performDbOperation('/api/admin/db/restore', 'restore', {
              filename: this.selectedBackupFilename
            });
            if (!payload) return;
            await this.load();
            this.dbOpsMessage = `${payload.message || `Database restored from ${restoreName}`}. Restart the personal-dashboard to ensure the restored database is picked up.`;
            this.lockDashboardUntilRestart();
          },

          async loadNews() {
            try {
              const response = await fetch('/api/news/global.json');
              if (!response.ok) {
                throw new Error(`News request failed with ${response.status}`);
              }
              const data = await response.json();
              this.newsItems = Array.isArray(data?.items) ? data.items : [];
              this.newsError = '';
            } catch {
              this.newsItems = [];
              this.newsError = 'Failed to load global news.';
            }
          },

          filteredCategories() {
            if (!this.activePanelId) return [];
            return this.categories.filter((category) => category.panel_id === this.activePanelId);
          },

          displayCategories() {
            const q = this.linkSearch.trim();
            if (!q) return this.filteredCategories();
            return this.categories.filter((category) => this.categoryHasVisibleLinks(category));
          },

          matchesLinkSearch(linkName) {
            const q = this.linkSearch.trim().toLowerCase();
            if (!q) return true;
            return String(linkName || '').toLowerCase().includes(q);
          },

          categoryHasVisibleLinks(category) {
            const links = category?.links || [];
            if (links.length === 0) return false;
            return links.some((link) => this.matchesLinkSearch(link.name));
          },

          totalCategories() {
            return this.categories.length;
          },

          totalLinks() {
            return this.categories.reduce(
              (sum, category) => sum + ((category.links || []).length),
              0
            );
          },

          getCategoryById(categoryId) {
            return this.categories.find((category) => category.id === categoryId);
          },

          firstCategoryInPanel(panelId) {
            const candidates = this.categories
              .filter((category) => category.panel_id === panelId)
              .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
            return candidates[0] || null;
          },

          switchPanel(panelId) {
            this.activePanelId = panelId;
            if (
              this.form.categoryId &&
              !this.filteredCategories().some((category) => category.id === this.form.categoryId)
            ) {
              this.form.categoryId = '';
            }
          },

          getFaviconUrl(linkUrl) {
            try {
              const parsed = new URL(linkUrl);
              return `https://www.google.com/s2/favicons?sz=64&domain=${encodeURIComponent(parsed.hostname)}`;
            } catch {
              return this.getFallbackFavicon();
            }
          },

          getFallbackFavicon() {
            const svg = `
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">
                <rect width="64" height="64" rx="12" fill="#2d2d2d"/>
                <circle cx="22" cy="24" r="6" fill="#ffd319"/>
                <rect x="20" y="34" width="24" height="6" rx="3" fill="#ffd319"/>
              </svg>
            `.trim();
            return `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
          },

          onFaviconError(event) {
            const fallback = this.getFallbackFavicon();
            if (event?.target && event.target.src !== fallback) {
              event.target.src = fallback;
            }
          },

          onPanelDragStart(panelId, event) {
            this.dragPanelId = panelId;
            if (event?.dataTransfer) {
              event.dataTransfer.effectAllowed = 'move';
            }
          },

          async onPanelDrop(targetPanelId, event) {
            if (!this.dragPanelId || this.dragPanelId === targetPanelId) return;
            const orderedPanels = [...this.panels];
            const sourceIndex = orderedPanels.findIndex((panel) => panel.id === this.dragPanelId);
            const targetIndex = orderedPanels.findIndex((panel) => panel.id === targetPanelId);
            if (sourceIndex < 0 || targetIndex < 0) return;

            let insertAfter = false;
            if (event?.currentTarget) {
              const rect = event.currentTarget.getBoundingClientRect();
              const midpoint = rect.left + rect.width / 2;
              insertAfter = event.clientX > midpoint;
            }

            let destinationIndex = targetIndex + (insertAfter ? 1 : 0);
            if (sourceIndex < destinationIndex) {
              destinationIndex -= 1;
            }

            const [movedPanel] = orderedPanels.splice(sourceIndex, 1);
            orderedPanels.splice(destinationIndex, 0, movedPanel);
            this.panels = orderedPanels;

            await fetch('/api/panels/reorder', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                orderedPanelIds: orderedPanels.map((panel) => panel.id)
              })
            });
            this.onDragEnd();
          },

          onCategoryDragStart(categoryId, event) {
            this.dragCategoryId = categoryId;
            if (event?.dataTransfer) {
              event.dataTransfer.effectAllowed = 'move';
            }
          },

          async onCategoryDrop(targetCategoryId) {
            if (!this.dragCategoryId || this.dragCategoryId === targetCategoryId) return;

            const visible = this.filteredCategories();
            const sourceIndex = visible.findIndex((category) => category.id === this.dragCategoryId);
            const targetIndex = visible.findIndex((category) => category.id === targetCategoryId);
            if (sourceIndex < 0 || targetIndex < 0) return;

            const [moved] = visible.splice(sourceIndex, 1);
            visible.splice(targetIndex, 0, moved);

            for (let i = 0; i < visible.length; i += 1) {
              visible[i].sort_order = i + 1;
            }

            const visibleIds = new Set(visible.map((category) => category.id));
            this.categories = [
              ...this.categories.filter((category) => !visibleIds.has(category.id)),
              ...visible
            ];

            await fetch('/api/categories/reorder', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                panelId: this.activePanelId,
                orderedCategoryIds: visible.map((category) => category.id)
              })
            });
          },

          onLinkDragStart(linkId, categoryId, event) {
            this.dragLinkId = linkId;
            this.dragFromCategoryId = categoryId;
            if (event?.dataTransfer) {
              event.dataTransfer.effectAllowed = 'move';
            }
          },

          async onLinkDrop(targetCategoryId, targetLinkId, event) {
            await this.moveDraggedLink(targetCategoryId, targetLinkId, event);
          },

          async onLinkDropToCategoryEnd(targetCategoryId) {
            await this.moveDraggedLink(targetCategoryId, null);
          },

          async onPanelTabDrop(panelId, event) {
            if (this.dragPanelId) {
              await this.onPanelDrop(panelId, event);
              return;
            }

            if (!this.dragLinkId || !this.dragFromCategoryId) return;
            const targetCategory = this.firstCategoryInPanel(panelId);
            if (!targetCategory) {
              this.errorMessage = 'Create a category in this panel before dropping links.';
              this.onDragEnd();
              return;
            }
            this.activePanelId = panelId;
            await this.moveDraggedLink(targetCategory.id, null);
          },

          async moveDraggedLink(targetCategoryId, targetLinkId = null, event = null) {
            if (!this.dragLinkId || !this.dragFromCategoryId) return;

            const sourceCategory = this.getCategoryById(this.dragFromCategoryId);
            const targetCategory = this.getCategoryById(targetCategoryId);
            if (!sourceCategory || !targetCategory) return;

            const sourceLinks = sourceCategory.links || [];
            const sourceIndex = sourceLinks.findIndex((link) => link.id === this.dragLinkId);
            if (sourceIndex < 0) return;

            const [movedLink] = sourceLinks.splice(sourceIndex, 1);
            movedLink.category_id = targetCategoryId;

            const targetLinks = targetCategory.links || [];
            if (targetLinkId == null) {
              targetLinks.push(movedLink);
            } else {
              const targetIndex = targetLinks.findIndex((link) => link.id === targetLinkId);
              if (targetIndex < 0) {
                targetLinks.push(movedLink);
              } else {
                let insertIndex = targetIndex;
                if (event?.currentTarget) {
                  const rect = event.currentTarget.getBoundingClientRect();
                  const offsetY = event.clientY - rect.top;
                  if (offsetY > rect.height / 2) {
                    insertIndex = targetIndex + 1;
                  }
                }
                targetLinks.splice(insertIndex, 0, movedLink);
              }
            }

            await this.persistLinkOrder();
          },

          async persistLinkOrder() {
            const payload = [];
            for (const category of this.categories) {
              for (let i = 0; i < (category.links || []).length; i += 1) {
                const link = category.links[i];
                link.sort_order = i + 1;
                payload.push({
                  id: link.id,
                  categoryId: category.id,
                  sortOrder: i + 1
                });
              }
            }

            if (payload.length > 0) {
              await fetch('/api/links/reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: payload })
              });
            }
            this.onDragEnd();
          },

          onDragEnd() {
            this.dragPanelId = null;
            this.dragCategoryId = null;
            this.dragLinkId = null;
            this.dragFromCategoryId = null;
          },

          async addCategory() {
            if (!this.newCategory.trim()) return;
            log('category:create', { name: this.newCategory });
            const response = await fetch('/api/categories', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name: this.newCategory })
            });
            if (!response.ok) {
              const payload = await response.json().catch(() => ({}));
              this.categoryErrorMessage = payload.error || 'Failed to create category';
              return;
            }
            const created = await response.json().catch(() => ({}));
            this.newCategory = '';
            this.categoryErrorMessage = '';
            await this.load();
            if (created?.panel_id) {
              this.activePanelId = created.panel_id;
            }
            this.showCategoryModal = false;
          },

          startEdit(link) {
            log('link:edit:start', { id: link.id });
            const category = this.categories.find((item) => item.id === link.category_id);
            if (category?.panel_id) {
              this.activePanelId = category.panel_id;
            }
            this.editingId = link.id;
            this.form = {
              name: link.name,
              url: link.url,
              description: link.description,
              categoryId: link.category_id
            };
            this.linkErrorMessage = '';
            this.showLinkModal = true;
          },

          resetForm() {
            log('link:edit:reset');
            this.editingId = null;
            this.form = { name: '', url: '', description: '', categoryId: '' };
          },

          async submitLink() {
            const payload = {
              ...this.form,
              categoryId: Number(this.form.categoryId)
            };

            let response;
            if (this.editingId) {
              log('link:update', { id: this.editingId });
              response = await fetch(`/api/links/${this.editingId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
            } else {
              log('link:create', { categoryId: payload.categoryId });
              response = await fetch('/api/links', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
            }

            if (!response.ok) {
              const payloadError = await response.json().catch(() => ({}));
              this.linkErrorMessage = payloadError.error || 'Failed to save link';
              return;
            }

            this.resetForm();
            this.linkErrorMessage = '';
            this.showLinkModal = false;
            await this.load();
          },

          async deleteLink(id) {
            log('link:delete', { id });
            await fetch(`/api/links/${id}`, { method: 'DELETE' });
            await this.load();
          },

          async deleteCategory(id) {
            log('category:delete', { id });
            const response = await fetch(`/api/categories/${id}`, { method: 'DELETE' });
            if (!response.ok) {
              const payload = await response.json().catch(() => ({}));
              const message = payload.error || 'Failed to delete category';
              window.alert(message);
              return;
            }
            if (this.form.categoryId === id) this.resetForm();
            await this.load();
          }
        };
      };
    </script>
  </body>
</html>
